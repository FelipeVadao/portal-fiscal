# URL do projeto Supabase (Settings > API)
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Service role key (Settings > API Keys) — NUNCA expor ao browser,
# só é lida em código server-side (API routes / Server Components).
SUPABASE_SERVICE_ROLE_KEY=

# Mesma URL de cima, mas com o prefixo NEXT_PUBLIC_ — usada pelo cliente
# Supabase que roda no navegador só para o upload de arquivo via signed URL
# (uploadToSignedUrl). Necessário porque documentos podem passar de 4.5MB,
# o limite de payload de uma Vercel Function — o upload vai direto
# navegador → Supabase Storage, não passa pelo servidor Next.js.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Anon/publishable key (Settings > API Keys) — diferente da service role,
# essa É segura para expor no navegador (a segurança vem do RLS, não de
# manter essa chave em segredo).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Senha usada para criptografar os cookies de sessão (iron-session).
# Gerar com: openssl rand -base64 32   (precisa ter pelo menos 32 caracteres)
SESSION_SECRET=

# Código de convite exigido para um novo contador se cadastrar em /registro.html
CONTADOR_INVITE_CODE=

# Connection string direta do Postgres (Connect > Session/Transaction pooler
# no dashboard do projeto) — só usada por scripts/run-migration.mjs para
# aplicar migrations (CREATE TABLE etc.), a aplicação em si nunca usa isso.
DATABASE_URL=

# API key do Resend (resend.com > API Keys) — usada por lib/email/resend.ts
# para enviar e-mails de notificação (nova solicitação, prazo próximo).
RESEND_API_KEY=

# Remetente dos e-mails. Sem domínio verificado no Resend, só
# "onboarding@resend.dev" funciona, e mesmo assim só entrega pro e-mail da
# própria conta Resend (não pra clientes reais) — ver CLAUDE.md. Trocar pra
# algo como "Portal Fiscal <notificacoes@seudominio.com>" assim que um
# domínio for verificado.
EMAIL_FROM="Portal Fiscal <onboarding@resend.dev>"

# URL base do app, usada só server-side para montar os links dentro dos
# e-mails (nunca chega ao browser). Default já aponta pra produção.
APP_URL=https://portal-fiscal-wine.vercel.app

# Segredo compartilhado com o Vercel Cron (Settings > Env Vars, e o Vercel
# manda automaticamente como "Authorization: Bearer <valor>" ao chamar
# /api/cron/prazos) — gerar com: openssl rand -base64 32
CRON_SECRET=

# API key do Gemini (Google AI Studio, aistudio.google.com/apikey — plano
# gratuito) — usada por lib/ai/validarDocumento.ts pra conferir se o arquivo
# enviado pelo cliente bate com o tipo de documento pedido na solicitação.
# Sem essa variável, a verificação é pulada (best-effort, nunca bloqueia o
# upload).
GEMINI_API_KEY=

# Modelo do Gemini a usar. Opcional — default já é o alias "sempre atual"
# da Google (evita quebrar quando um modelo específico é descontinuado).
GEMINI_MODEL=gemini-flash-latest

# Par de chaves VAPID para push notifications (Web Push). Geradas localmente
# (sem cadastro em provedor nenhum) — rodar uma vez:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# e nunca mais trocar (trocar invalida as inscrições já salvas dos clientes).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Mesma chave pública acima, só que exposta ao navegador (é pública por
# natureza — a segurança do Web Push vem da chave privada, que fica só no
# servidor). Usada por components/portal/PushNotificationToggle.tsx.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
